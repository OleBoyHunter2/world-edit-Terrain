{
	"schemaVersion": 1,
	"id": "terrain-addon",
	"version": "${version}",
	"name": "TerrainAddon",
	"description": "this addon to worldedite allows you to make easy terrain with one command just do //terrain <noise pattern> <height> <scale> <octaves> <roughness> <block>",
	"authors": [
		"oleboyhunter"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/terrain-addon/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.oleboyterrain.TerrainAddonMod"
		],

		"fabric-datagen": [
			"com.oleboyterrain.TerrainAddonDataGenerator"
		]
	},
	"mixins": [
		"terrain-addon.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.1",
		"minecraft": "~1.21.10",
		"java": ">=21",
		"fabric-api": "*",
		"worldedit": "*"
	}
}
